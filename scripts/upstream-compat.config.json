{
  "packageName": "@anthropic-ai/claude-code",
  "baseline": {
    "versions": ["2.1.92", "2.1.97", "2.1.104", "2.1.107", "2.1.110", "2.1.112"],
    "includeLatestFromNpm": false
  },
  "checks": {
    "sentinels": [
      { "id": "quick_safety_check", "pattern": "Quick safety check" },
      { "id": "security_guide", "pattern": "Security guide" },
      {
        "id": "btw_prompt",
        "pattern": "Use /btw to ask a quick side question without interrupting Claude's current work"
      },
      { "id": "approval_reason", "pattern": "This command requires approval" },
      { "id": "proceed_prompt", "pattern": "Do you want to proceed?" },
      { "id": "tab_to_amend", "pattern": "Tab to amend" },
      { "id": "ctrl_e_to_explain", "pattern": "ctrl+e to explain" }
    ],
    "templateResidues": [
      { "id": "duration_worked", "pattern": "Worked for" },
      { "id": "duration_idle", "pattern": "Idle for" },
      { "id": "duration_guarded", "regex": "&&`\\$\\{[^}]+\\} for \\$\\{[^}]+\\}`" },
      { "id": "duration_literal_connector", "regex": ",\\s*\" for \"\\s*," }
    ],
    "upstreamTextGuards": [
      {
        "id": "advisor_prompt_tool_name",
        "rule": "preserve",
        "pattern": "# Advisor Tool\n\nYou have access to an \\`advisor\\` tool"
      },
      {
        "id": "advisor_dialog_title",
        "rule": "preserve",
        "pattern": "title:\"Advisor Tool\""
      },
      {
        "id": "stop_ultrareview_label",
        "rule": "translate",
        "sourcePattern": "label:\"Stop ultrareview\"",
        "pattern": "label:\"停止 ultrareview\""
      },
      {
        "id": "ultrareview_billing_template",
        "rule": "template",
        "sourceRegex": "body:`This review bills as Extra Usage \\(\\$\\{[^}]+\\}\\)\\.`",
        "regex": "body:`本次 review 会按 Extra Usage 计费（\\$\\{[^}]+\\}）。`"
      },
      {
        "id": "ultrareview_launch_template",
        "rule": "template",
        "sourceRegex": "text:`\\$\\{[^}]+\\}Ultrareview launched for \\$\\{[^}]+\\} \\(\\$\\{[^}]+\\}, runs in the cloud\\)\\. Track: \\$\\{[^}]+\\}\\$\\{[^}]+\\}`",
        "regex": "text:`\\$\\{[^}]+\\}Ultrareview 已为 \\$\\{[^}]+\\} 启动（\\$\\{[^}]+\\}，云端运行）。跟踪：\\$\\{[^}]+\\}\\$\\{[^}]+\\}`"
      }
    ],
    "displayAudit": {
      "commands": [
        { "id": "top_help", "args": ["--help"] },
        { "id": "agents_help", "args": ["agents", "--help"], "optional": true },
        { "id": "auth_help", "args": ["auth", "--help"], "optional": true },
        { "id": "auto_mode_help", "args": ["auto-mode", "--help"], "optional": true },
        { "id": "doctor_help", "args": ["doctor", "--help"], "optional": true },
        { "id": "install_help", "args": ["install", "--help"], "optional": true },
        { "id": "mcp_help", "args": ["mcp", "--help"], "optional": true },
        { "id": "plugin_help", "args": ["plugin", "--help"], "optional": true },
        { "id": "setup_token_help", "args": ["setup-token", "--help"], "optional": true },
        { "id": "update_help", "args": ["update", "--help"], "optional": true },
        { "id": "ultrareview_help", "args": ["ultrareview", "--help"], "optional": true }
      ],
      "blockedPhrases": [
        { "id": "usage_heading", "pattern": "Usage:" },
        { "id": "arguments_heading", "pattern": "Arguments:" },
        { "id": "options_heading", "pattern": "Options:" },
        { "id": "commands_heading", "pattern": "Commands:" },
        { "id": "your_prompt", "pattern": "Your prompt" },
        { "id": "display_help_for_command", "pattern": "Display help for command" },
        { "id": "interactive_session_description", "pattern": "starts an interactive session by default" },
        { "id": "install_target_hint", "pattern": "Use [target] to specify version" }
      ],
      "mustPreserve": [
        { "id": "top_model_flag", "command": "top_help", "pattern": "--model" },
        { "id": "top_print_flag", "command": "top_help", "pattern": "--print" },
        { "id": "top_json_schema_term", "command": "top_help", "pattern": "JSON Schema" },
        { "id": "top_anthropic_api_key", "command": "top_help", "pattern": "ANTHROPIC_API_KEY" },
        { "id": "top_mcp_term", "command": "top_help", "pattern": "MCP" },
        { "id": "top_stream_json_value", "command": "top_help", "pattern": "stream-json" }
      ],
      "allowedEnglishTerms": [
        "Claude Code",
        "Claude",
        "Anthropic",
        "Agent",
        "API",
        "MCP",
        "JSON",
        "Schema",
        "PR",
        "IDE",
        "OAuth",
        "Bedrock",
        "Vertex",
        "Foundry",
        "LSP",
        "Hook",
        "Bash",
        "Edit",
        "Read",
        "UUID",
        "URL",
        "Sonnet",
        "Opus",
        "tmux",
        "iTerm2",
        "TTY",
        "stdin",
        "stdout",
        "npm",
        "stable",
        "latest",
        "stream-json"
      ],
      "allowedEnglishLineRegexes": [
        "^\\s*[a-z][a-z0-9-]*(\\|[a-z][a-z0-9-]*)?(\\s+\\[[^\\]]+\\])?$",
        "^\\s*claude\\s+.*$"
      ],
      "minEnglishWords": 2,
      "maxUntranslatedLines": 0
    }
  },
  "support": {
    "npm": {
      "stable": {
        "floor": "2.1.92",
        "ceiling": "2.1.112",
        "representatives": ["2.1.92", "2.1.97", "2.1.104", "2.1.107", "2.1.110", "2.1.112"],
        "notes": "PATH 优先 launcher + session-start 二层兜底，适用于旧 cli.js npm 包形态；2.1.113+ native binary wrapper 暂不支持旧 CLI Patch。"
      }
    },
    "macosOfficialInstaller": {
      "experimental": {
        "platform": "darwin-arm64",
        "floor": "2.1.110",
        "ceiling": "2.1.112",
        "representatives": ["2.1.110", "2.1.111", "2.1.112"],
        "requires": ["node-lief"],
        "verification": "2.1.110 PASS(native 1245) · 2.1.111 PASS(native 1241) · 2.1.112 PASS(native 1241)",
        "notes": "官方安装器指定旧版本仍走 native binary；macOS arm64 已离线验证 extract/patch/repack/--version，插件可用 native patch experimental 处理，需要 node-lief；稳定使用仍建议 npm pinned。"
      }
    },
    "macosNativeExperimental": {
      "platform": "darwin-arm64",
      "packageName": "@anthropic-ai/claude-code-darwin-arm64",
      "floor": "2.1.123",
      "ceiling": "2.1.123",
      "representatives": ["2.1.123"],
      "verification": "2.1.123 PASS(native 1334, display 11/11)",
      "requires": ["node-lief"],
      "notes": "macOS arm64 native binary experimental；需要 node-lief；已验证 extract / patch / repack / --version 和 11 个稳定显示面审计；只对明确验证版本开放，不代表未来 latest 自动稳定。"
    },
    "linuxOfficialInstaller": {
      "unsupported": true,
      "notes": "当前不支持 Linux 官方安装器；请改用 npm 路径。"
    },
    "windowsNpmPowerShell": {
      "stable": {
        "floor": "2.1.92",
        "ceiling": "2.1.112",
        "representatives": [],
        "notes": "新增 PowerShell 安装脚本（install.ps1）；适用于旧 npm cli.js 形态，CLI Patch 可用；Windows 上 session-start 二层兜底（launcher 暂不实现启动前自修复）。"
      }
    },
    "windowsNativeExe": {
      "unsupported": true,
      "notes": "Windows native .exe（官方安装器或 2.1.113+ npm 原生 wrapper）会明确跳过 CLI Patch，仅启用 Layer 1~3；硬编码 UI 文字不会被完整翻译。"
    }
  }
}
