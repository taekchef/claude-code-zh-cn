#!/usr/bin/env bash
# notification hook for claude-code-zh-cn
# Translates common notifications using the active locale's translation data
# 通过 i18n.js 模块加载翻译，无需硬编码

read -r INPUT

# Extract notification message
MESSAGE=$(ZH_CN_NOTIFICATION_INPUT="$INPUT" node -e "
try {
  const data = JSON.parse(process.env.ZH_CN_NOTIFICATION_INPUT || '{}');
  process.stdout.write(String(data.message || ''));
} catch {}
" 2>/dev/null)

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$HOME/.claude/plugins/claude-code-zh-cn}"

# 通过 i18n 模块翻译通知
TRANSLATED="$(PLUGIN_ROOT="$PLUGIN_ROOT" ZH_CN_MESSAGE="$MESSAGE" node -e "
const i18n = require(process.env.PLUGIN_ROOT + '/core/i18n.js');
const locale = i18n.loadActiveLocale();
const msg = process.env.ZH_CN_MESSAGE || '';

if (locale && locale.notifications) {
  for (const [key, value] of Object.entries(locale.notifications)) {
    if (msg.includes(key)) {
      process.stdout.write(value);
      break;
    }
  }
}
" 2>/dev/null)"

# Output translated notification if found
if [ -n "$TRANSLATED" ]; then
    cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "Notification",
    "additionalContext": "通知翻译：$TRANSLATED"
  }
}
EOF
else
    echo '{}'
fi
